.model cosim7 d_cosim(simulation="./cosim/libavr_cosim.so" sim_args=["atmega328p","toggle.hex"] queue_size=1024 irreversible=1 delay=1e-9)
.model cosim8 d_cosim(simulation="./cosim/libavr_cosim.so" sim_args=["atmega328p","toggle.hex"] queue_size=1024 irreversible=1 delay=1e-9)
.model cosim9 d_cosim(simulation="./cosim/libavr_cosim.so" sim_args=["atmega328p","toggle.hex"] queue_size=1024 irreversible=1 delay=1e-9)
.model cosim10 d_cosim(simulation="./cosim/libavr_cosim.so" sim_args=["atmega328p","toggle.hex"] queue_size=1024 irreversible=1 delay=1e-9)

.options reltol=0.005 method=gear trtol=7 chgtol=1e-13
.tran 5us 300us
.control
run
print v(pb0_an1) v(pb0_an2) v(pb0_an3) v(pb0_an4) v(pb0_an5) v(pb0_an6) v(pb0_an7) v(pb0_an8) v(pb0_an9) v(pb0_an10)

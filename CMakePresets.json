{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25
    },
    "configurePresets": [
        {
            "name": "release",
            "displayName": "Release (Ninja, ccache, unity build)",
            "description": "Canonical VioAVR build — Ninja generator, Release, ccache, unity build",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "VIOAVR_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug (Ninja, ccache, unity build)",
            "description": "Debug build with tests and sanitisers",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "VIOAVR_BUILD_TESTS": "ON",
                "VIOAVR_ENABLE_SANITIZERS": "ON",
                "VIOAVR_ENABLE_WERROR": "ON"
            }
        },
        {
            "name": "ci-release",
            "displayName": "Release (CI — no native arch, any generator)",
            "description": "CI build — portable, no cosim, no -march=native",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "VIOAVR_BUILD_TESTS": "ON",
                "VIOAVR_USE_NATIVE_ARCH": "OFF",
                "VIOAVR_ALLOW_ANY_GENERATOR": "ON",
                "VIOAVR_BUILD_COSIM": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "release",
            "configurePreset": "release",
            "jobs": 8,
            "description": "Build all targets (Release)"
        },
        {
            "name": "debug",
            "configurePreset": "debug",
            "jobs": 8,
            "description": "Build all targets (Debug)"
        }
    ],
    "testPresets": [
        {
            "name": "release",
            "configurePreset": "release",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "jobs": 8,
                "timeout": 300
            },
            "description": "Run all tests (Release)"
        }
    ]
}
